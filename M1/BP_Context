// ============================================================
// Hilfsfunktionen für den Skill Tree
// ============================================================

// Gesamtanzahl Handlungskompetenzen
BILDUNGSPLAN.getTotalKompetenzen = function() {
  return this.branches.reduce((sum, b) => sum + b.kompetenzen.length, 0);
};

// Gesamtanzahl Lernziele
BILDUNGSPLAN.getTotalLernziele = function() {
  return this.branches.reduce((sum, b) =>
    sum + b.kompetenzen.reduce((s, k) => s + k.lernziele.length, 0), 0);
};

// Alle Kompetenz-IDs flach als Array
BILDUNGSPLAN.getAllKompetenzIds = function() {
  return this.branches.flatMap(b => b.kompetenzen.map(k => k.id));
};

// Kompetenz anhand ID finden
BILDUNGSPLAN.findKompetenz = function(id) {
  for (const branch of this.branches) {
    const k = branch.kompetenzen.find(k => k.id === id);
    if (k) return { branch, kompetenz: k };
  }
  return null;
};

// Statistik: { total, ueks, branches, kompetenzen, lernziele }
BILDUNGSPLAN.getStats = function() {
  return {
    ueks: this.ueks.length,
    branches: this.branches.length,
    kompetenzen: this.getTotalKompetenzen(),
    lernziele: this.getTotalLernziele(),
  };
};

